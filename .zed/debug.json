[
  {
    "label": "Tauri Dev (Rust Core)",
    "adapter": "CodeLLDB",
    "request": "launch",
    "sourceLanguages": ["rust"],
    "build": {
      "command": "cargo",
      "args": ["build", "--manifest-path", "src-tauri/Cargo.toml"]
    },
    "program": "$ZED_WORKTREE_ROOT/src-tauri/target/debug/weilens",
    "cwd": "$ZED_WORKTREE_ROOT/src-tauri",
    "env": {
      "RUST_BACKTRACE": "1",
      "RUST_LOG": "debug"
    }
  }
]
